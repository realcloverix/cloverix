local Cleaner = loadstring(game:HttpGet("https://raw.githubusercontent.com/realcloverix/cloverix/refs/heads/main/cleaner"))();
local Signal = loadstring(game:HttpGet("https://raw.githubusercontent.com/realcloverix/cloverix/refs/heads/main/signal"))();
local Services = loadstring(game:HttpGet("https://raw.githubusercontent.com/realcloverix/cloverix/refs/heads/main/services"))();

local TweenService, CoreGui, GuiService, TextService =
    Services:Get("TweenService", "CoreGui", "GuiService", "TextService");

local ProtectGui, GetHUI =
    protectgui or (syn and syn.protect_gui) or function() end,
    gethui or function() return CoreGui end;

local ActiveNotifications = {};
local NotificationSystem = {};
local Notification = {};
NotificationSystem.__index = NotificationSystem;
Notification.__index = Notification;

--// CLOVERIX GREEN THEME 🌿
local Theme, Icons, Container;

do
    Theme = {
        Background = Color3.fromRGB(10, 18, 12),
        BackgroundSecondary = Color3.fromRGB(18, 30, 22),
        Text = Color3.fromRGB(240, 255, 245),
        SubText = Color3.fromRGB(170, 200, 180),
        Border = Color3.fromRGB(40, 80, 55),

        Info = Color3.fromRGB(70, 200, 120),
        Success = Color3.fromRGB(90, 255, 160),
        Warning = Color3.fromRGB(255, 200, 80),
        Error = Color3.fromRGB(255, 90, 90),
    };

    -- CLOVERIX RUNE ICON SET 🌿
    Icons = {
        Info = "᚛",
        Success = "ᚖ",
        Warning = "ᚠ",
        Error = "ᚷ"
    };
end;

--// CONTAINER
do
    local chars = {};
    for i = 1, math.random(14, 22) do
        chars[i] = string.char(math.random(97, 122));
    end;

    Container = Instance.new("ScreenGui");
    Container.Name = "cloverix_" .. table.concat(chars);
    Container.ResetOnSpawn = false;
    Container.ZIndexBehavior = Enum.ZIndexBehavior.Sibling;
    Container.DisplayOrder = 999999;
    ProtectGui(Container);
    Container.Parent = GetHUI();
end;

--// NOTIFICATION CORE
do
    local Padding = {
        Frame = 16,
        IconGap = 12,
        TitleTop = 22,
        MessageGap = 4,
        Right = 16,
        Bottom = 18
    };

    function Notification.new(options)
        local self = setmetatable({
            Type = options.Type or "Info",
            Title = options.Title or "Cloverix",
            Text = options.Text or "",
            Duration = options.Duration or 5,
            Callback = options.Callback,
            Destroying = Signal.new(),

            _maid = Cleaner.new(),
            _destroyed = false
        }, Notification);

        self:_build();
        return self;
    end;

    function Notification:_calculateSize()
        local viewport = workspace.CurrentCamera.ViewportSize;
        local screenW = viewport.X;

        local scale = math.clamp(screenW / 1920, 0.75, 1);
        local width = math.floor(380 * scale);
        local iconSize = math.floor(36 * scale);

        local contentX = Padding.Frame + iconSize + Padding.IconGap;
        local contentWidth = width - contentX - Padding.Right;

        local titleSize = math.floor(15 * scale);
        local messageSize = math.floor(13 * scale);

        local titleBounds = TextService:GetTextSize(
            self.Title,
            titleSize,
            Enum.Font.GothamBold,
            Vector2.new(contentWidth - 30, 50)
        );

        local messageBounds = TextService:GetTextSize(
            self.Text,
            messageSize,
            Enum.Font.Gotham,
            Vector2.new(contentWidth, 500)
        );

        local height =
            Padding.TitleTop +
            titleBounds.Y +
            Padding.MessageGap +
            messageBounds.Y +
            Padding.Bottom;

        height = math.clamp(height, 70, 180);

        return width, height, scale, iconSize, contentX, titleSize, messageSize, titleBounds.Y;
    end;

    function Notification:_build()
        local color = Theme[self.Type] or Theme.Info;
        local width, height, scale, iconSize, contentX, titleSize, messageSize, titleHeight =
            self:_calculateSize();

        local frame = Instance.new("Frame");
        frame.Size = UDim2.fromOffset(width, height);
        frame.Position = UDim2.new(0, 20, 1, height + 30);
        frame.BackgroundColor3 = Theme.Background;
        frame.BorderSizePixel = 0;
        frame.AnchorPoint = Vector2.new(0, 1);
        frame.ClipsDescendants = true;
        frame.Parent = Container;

        self.Frame = frame;

        Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 8);

        local stroke = Instance.new("UIStroke", frame);
        stroke.Color = Theme.Border;
        stroke.Thickness = 1;
        stroke.Transparency = 0.4;

        local accent = Instance.new("Frame", frame);
        accent.Size = UDim2.new(0, 3, 1, 0);
        accent.BackgroundColor3 = color;
        accent.BorderSizePixel = 0;

        Instance.new("UICorner", accent).CornerRadius = UDim.new(0, 8);

        local iconContainer = Instance.new("Frame", frame);
        iconContainer.Size = UDim2.fromOffset(iconSize, iconSize);
        iconContainer.Position = UDim2.new(0, Padding.Frame, 0.5, 0);
        iconContainer.AnchorPoint = Vector2.new(0, 0.5);
        iconContainer.BackgroundColor3 = color;
        iconContainer.BackgroundTransparency = 0.88;
        iconContainer.BorderSizePixel = 0;

        Instance.new("UICorner", iconContainer).CornerRadius = UDim.new(0.5, 0);

        local icon = Instance.new("TextLabel", iconContainer);
        icon.Size = UDim2.fromScale(1, 1);
        icon.BackgroundTransparency = 1;
        icon.Text = Icons[self.Type] or Icons.Info;
        icon.Font = Enum.Font.GothamBold;
        icon.TextSize = math.floor(14 * scale);
        icon.TextColor3 = color;

        local title = Instance.new("TextLabel", frame);
        title.Size = UDim2.new(1, -contentX - Padding.Right, 0, titleHeight);
        title.Position = UDim2.new(0, contentX, 0, Padding.TitleTop);
        title.BackgroundTransparency = 1;
        title.Text = self.Title;
        title.Font = Enum.Font.GothamBold;
        title.TextSize = titleSize;
        title.TextColor3 = Theme.Text;
        title.TextXAlignment = Enum.TextXAlignment.Left;

        local message = Instance.new("TextLabel", frame);
        message.Size = UDim2.new(1, -contentX - Padding.Right, 0, height);
        message.Position = UDim2.new(0, contentX, 0, Padding.TitleTop + titleHeight + Padding.MessageGap);
        message.BackgroundTransparency = 1;
        message.Text = self.Text;
        message.Font = Enum.Font.Gotham;
        message.TextSize = messageSize;
        message.TextColor3 = Theme.SubText;
        message.TextWrapped = true;
        message.TextXAlignment = Enum.TextXAlignment.Left;

        local closeBtn = Instance.new("TextButton", frame);
        closeBtn.Size = UDim2.fromOffset(16, 16);
        closeBtn.Position = UDim2.new(1, -Padding.Right, 0, Padding.TitleTop);
        closeBtn.BackgroundTransparency = 1;
        closeBtn.Text = "x";
        closeBtn.Font = Enum.Font.GothamBold;
        closeBtn.TextSize = math.floor(12 * scale);
        closeBtn.TextColor3 = Theme.SubText;

        closeBtn.MouseButton1Click:Connect(function()
            self:Destroy();
        end);

        table.insert(ActiveNotifications, self);
        self:_updatePositions();

        TweenService:Create(frame, TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
            Position = UDim2.new(0, 20, 1, -20)
        }):Play();

        task.delay(self.Duration, function()
            if not self._destroyed then
                self:Destroy();
            end
        end);
    end;

    function Notification:_updatePositions()
        local totalHeight = 20;

        for i = #ActiveNotifications, 1, -1 do
            local notif = ActiveNotifications[i];
            if notif and not notif._destroyed then
                TweenService:Create(notif.Frame, TweenInfo.new(0.35, Enum.EasingStyle.Quint), {
                    Position = UDim2.new(0, 20, 1, -totalHeight)
                }):Play();

                local _, h = notif:_calculateSize();
                totalHeight += h + 8;
            end;
        end;
    end;

    function Notification:Destroy()
        if self._destroyed then return end;
        self._destroyed = true;

        local idx = table.find(ActiveNotifications, self);
        if idx then table.remove(ActiveNotifications, idx) end;

        TweenService:Create(self.Frame, TweenInfo.new(0.3), {
            BackgroundTransparency = 1
        }):Play();

        task.delay(0.2, function()
            if self.Frame then
                self.Frame:Destroy();
            end
            self._maid:Clean();
        end);

        self:_updatePositions();
    end;
end;

--// SYSTEM
do
    function NotificationSystem.new()
        return setmetatable({ _maid = Cleaner.new() }, NotificationSystem);
    end;

    function NotificationSystem:Notify(title, message, t, duration, callback)
        return Notification.new({
            Title = title,
            Text = message,
            Type = t or "Info",
            Duration = duration,
            Callback = callback
        });
    end;

    function NotificationSystem:Success(t, m, d, c)
        return self:Notify(t, m, "Success", d, c);
    end;

    function NotificationSystem:Warning(t, m, d, c)
        return self:Notify(t, m, "Warning", d, c);
    end;

    function NotificationSystem:Error(t, m, d, c)
        return self:Notify(t, m, "Error", d, c);
    end;

    function NotificationSystem:ClearAll()
        for _, n in ipairs(ActiveNotifications) do
            n:Destroy();
        end;
    end;

    function NotificationSystem:Destroy()
        self:ClearAll();
        self._maid:Clean();
    end;
end;

return NotificationSystem.new();
